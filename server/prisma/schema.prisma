generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FOUNDER
  MANAGER
  EXECUTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityAction {
  CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  FIELD_UPDATED
  IMPORTED
  CALLED
}

enum CallOutcome {
  CONNECTED
  NO_ANSWER
  VOICEMAIL
  CALL_BACK_LATER
  WRONG_NUMBER
}

enum ResourceCategory {
  MESSAGE
  EMAIL
  CALL_SCRIPT
}

enum LeadRequestStatus {
  PENDING
  APPROVED
  DENIED
}

// A rep asking for more leads once they've worked through their current book — distinct
// from the automatic capacity backfill (which fires silently on closing a lead). This one
// needs a Founder/Manager to look and say yes, since it's the rep asserting readiness
// rather than the system inferring it from a status change.
model LeadRequest {
  id     String            @id @default(cuid())
  userId String            @map("user_id")
  user   User              @relation("LeadRequestUser", fields: [userId], references: [id])
  status LeadRequestStatus @default(PENDING)
  note   String?

  requestedAt DateTime  @default(now()) @map("requested_at")
  resolvedAt  DateTime? @map("resolved_at")

  resolvedById String? @map("resolved_by_id")
  resolvedBy   User?   @relation("LeadRequestResolvedBy", fields: [resolvedById], references: [id])

  // True when the alerts sweep approved this itself (owner didn't act within the grace
  // window) rather than a human clicking Approve — resolvedById stays null in that case.
  autoApproved Boolean @default(false) @map("auto_approved")

  @@index([userId, status])
  @@map("lead_requests")
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  users           User[]
  assignmentRules AssignmentRule[]
  lastAssignedIdx Int              @default(0) @map("last_assigned_idx") // round-robin cursor

  @@map("teams")
}

model Service {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  leads           Lead[]
  assignmentRules AssignmentRule[]
  resources       Resource[]

  @@map("services")
}

// Message/email templates the team can copy and send to clients for a given service —
// e.g. an outreach draft for "AI Development" leads. Founder/Manager write these,
// everyone can view and copy them. Not tied to leads/comments — this is a shared library,
// not per-lead history.
model Resource {
  id        String           @id @default(cuid())
  title     String
  body      String
  category  ResourceCategory
  serviceId String?          @map("service_id")
  service   Service?         @relation(fields: [serviceId], references: [id])

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("ResourceCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category, serviceId])
  @@map("resources")
}

model LeadSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isOrganic Boolean  @default(true) @map("is_organic")
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@map("lead_sources")
}

model User {
  id                 String    @id @default(cuid())
  employeeId         String    @unique @map("employee_id")
  name               String
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               Role
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  isActive           Boolean   @default(true) @map("is_active")
  lastLoginAt        DateTime? @map("last_login_at")
  // Max open (non-Won/Lost) leads this person should hold at once. Round-robin
  // assignment skips reps at/over this; a rep going quiet on leads within capacity
  // gets those leads auto-redistributed rather than piling up further. Default is the
  // middle of the "48 to 88 leads, given only picked-up calls take real time" range.
  leadCapacity       Int       @default(60) @map("lead_capacity")
  // Expected shift, "HH:MM" 24-hour, compared against session loginAt in server-local time
  // (this app doesn't track per-user timezone — same assumption already made everywhere
  // else dates are handled). workDays uses JS Date.getDay() convention: 0=Sun..6=Sat.
  workStartTime      String    @default("09:00") @map("work_start_time")
  workEndTime        String    @default("18:00") @map("work_end_time")
  workDays           Int[]     @default([1, 2, 3, 4, 5]) @map("work_days")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  ownedLeads           Lead[]         @relation("LeadOwner")
  createdLeads         Lead[]         @relation("LeadCreatedBy")
  activities           LeadActivity[]
  auditLogs            AuditLog[]
  sessions             UserSession[]
  leadViews            LeadView[]
  idleFlags            IdleFlag[]
  createdResources     Resource[]     @relation("ResourceCreatedBy")
  leadRequests         LeadRequest[]  @relation("LeadRequestUser")
  resolvedLeadRequests LeadRequest[]  @relation("LeadRequestResolvedBy")

  // Composite covers plain "by team" lookups too (leftmost-prefix), and is the exact
  // shape of the round-robin assignment query (team + role + active), so one index
  // serves both instead of carrying a redundant single-column one alongside it.
  @@index([teamId, role, isActive])
  @@map("users")
}

// One row per login, closed out on explicit logout or (if the browser just closes) treated
// as ended at token expiry for reporting purposes. This is the source of truth for
// check-in/check-out time; daily/weekly/monthly/yearly summaries are computed from these
// rows rather than stored, so there's nothing to keep in sync.
model UserSession {
  id       String    @id @default(cuid())
  userId   String    @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt  DateTime  @default(now()) @map("login_at")
  logoutAt DateTime? @map("logout_at")

  // Real activity within this session, distinct from raw login-to-logout duration.
  // The client only sends a heartbeat when there's been mouse/keyboard/scroll activity
  // since the last one, so a gap here (heartbeat stops arriving) means the person is
  // away from the screen even though the session is technically still open.
  activeSeconds   Int       @default(0) @map("active_seconds")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")

  idleFlags IdleFlag[]

  @@index([userId])
  @@map("user_sessions")
}

// A discrete "away from screen 30+ minutes while still logged in" incident — recorded
// once per gap (not just folded into a number) so it shows up on that day's profile as
// something a manager can actually look at and raise in a 1:1, not just a stat.
model IdleFlag {
  id              String      @id @default(cuid())
  userId          String      @map("user_id")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String      @map("session_id")
  session         UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  flagDate        DateTime    @map("flag_date") @db.Date
  startedAt       DateTime    @map("started_at")
  endedAt         DateTime    @map("ended_at")
  durationMinutes Int         @map("duration_minutes")

  @@index([userId, flagDate])
  @@map("idle_flags")
}

model Lead {
  id            String  @id @default(cuid())
  companyName   String  @map("company_name")
  contactPerson String? @map("contact_person")
  phone         String?
  email         String?
  website       String?
  industry      String?
  city          String?
  state         String?
  country       String?
  notes         String?

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  sourceId String?     @map("source_id")
  source   LeadSource? @relation(fields: [sourceId], references: [id])

  ownerId String? @map("owner_id")
  owner   User?   @relation("LeadOwner", fields: [ownerId], references: [id])

  // Owner marked "I'm working this myself" — excluded from both the stale-lead
  // auto-reassignment sweep and the owner's open-lead capacity count for 30 days from
  // this timestamp, so keeping a lead they believe is workable doesn't block them from
  // receiving fresh ones. After 30 days it automatically returns to the normal pool
  // (re-eligible for reassignment/capacity) — no expiry job needed, just a date check.
  ownerPinnedAt DateTime? @map("owner_pinned_at")

  priority Priority   @default(MEDIUM)
  status   LeadStatus @default(NEW)

  expectedDealValue   Decimal?  @map("expected_deal_value") @db.Decimal(14, 2)
  probability         Int?
  expectedClosingDate DateTime? @map("expected_closing_date")
  lostReason          String?   @map("lost_reason")

  lastContactAt    DateTime? @map("last_contact_at")
  nextFollowUp     DateTime? @map("next_follow_up")
  firstContactedAt DateTime? @map("first_contacted_at")

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("LeadCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities LeadActivity[]
  // Team comments live here as a jsonb array (each entry: {id, userId, userName,
  // employeeId, body, createdAt}), appended atomically via a raw jsonb || update rather
  // than a separate table — there's no cross-lead comment query, so one row per lead
  // read/written together beats a join for this. Author name/ID is snapshotted at post
  // time, so a comment still shows who wrote it even if that account is later deleted.
  comments   Json           @default("[]") @map("comments")
  views      LeadView[]

  // Covers plain ownerId lookups, "my leads by status", and the neglected-leads query
  // (ownerId + status + stale updatedAt) via leftmost-prefix matching — one index instead
  // of three overlapping ones.
  @@index([ownerId, status, updatedAt])
  // Same idea for org-wide (Founder/Manager) views: plain status filtering, and future
  // "all neglected leads company-wide" queries.
  @@index([status, updatedAt])
  @@index([serviceId])
  @@index([phone])
  @@index([email])
  @@index([state])
  @@index([city])
  @@map("leads")
}

model LeadActivity {
  id        String         @id @default(cuid())
  leadId    String         @map("lead_id")
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?        @map("user_id")
  user      User?          @relation(fields: [userId], references: [id])
  action    ActivityAction
  notes     String?
  timestamp DateTime       @default(now())

  @@index([leadId])
  // Powers the Member Profile page: "this person's recent activity" and "this person's
  // calls" both filter by userId and sort by timestamp. Previously unindexed on userId
  // at all, which would have meant a full table scan per profile view at scale.
  @@index([userId, timestamp])
  @@map("lead_activities")
}

// One row per (lead, user, day) — "did this rep open this lead today", deduped so normal
// page re-renders/refetches don't inflate the count. Powers "profiles opened" metrics.
model LeadView {
  id       String   @id @default(cuid())
  leadId   String   @map("lead_id")
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewDate DateTime @map("view_date") @db.Date
  viewedAt DateTime @default(now()) @map("viewed_at")

  @@unique([leadId, userId, viewDate])
  @@index([userId])
  @@map("lead_views")
}

model AssignmentRule {
  id        String  @id @default(cuid())
  serviceId String  @unique @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])
  teamId    String  @map("team_id")
  team      Team    @relation(fields: [teamId], references: [id])

  @@map("assignment_rules")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}
