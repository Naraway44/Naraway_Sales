generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FOUNDER
  MANAGER
  EXECUTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityAction {
  CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  FIELD_UPDATED
  IMPORTED
  CALLED
}

enum CallOutcome {
  CONNECTED
  NO_ANSWER
  VOICEMAIL
  CALL_BACK_LATER
  WRONG_NUMBER
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  users           User[]
  assignmentRules AssignmentRule[]
  lastAssignedIdx Int              @default(0) @map("last_assigned_idx") // round-robin cursor

  @@map("teams")
}

model Service {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  leads           Lead[]
  assignmentRules AssignmentRule[]

  @@map("services")
}

model LeadSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isOrganic Boolean  @default(true) @map("is_organic")
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@map("lead_sources")
}

model User {
  id                 String    @id @default(cuid())
  employeeId         String    @unique @map("employee_id")
  name               String
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               Role
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  isActive           Boolean   @default(true) @map("is_active")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  ownedLeads   Lead[]         @relation("LeadOwner")
  createdLeads Lead[]         @relation("LeadCreatedBy")
  activities   LeadActivity[]
  comments     LeadComment[]
  auditLogs    AuditLog[]
  sessions     UserSession[]
  leadViews    LeadView[]

  @@index([teamId])
  @@map("users")
}

// One row per login, closed out on explicit logout or (if the browser just closes) treated
// as ended at token expiry for reporting purposes. This is the source of truth for
// check-in/check-out time; daily/weekly/monthly/yearly summaries are computed from these
// rows rather than stored, so there's nothing to keep in sync.
model UserSession {
  id       String    @id @default(cuid())
  userId   String    @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt  DateTime  @default(now()) @map("login_at")
  logoutAt DateTime? @map("logout_at")

  @@index([userId])
  @@map("user_sessions")
}

model Lead {
  id            String  @id @default(cuid())
  companyName   String  @map("company_name")
  contactPerson String? @map("contact_person")
  phone         String?
  email         String?
  website       String?
  industry      String?
  city          String?
  state         String?
  country       String?
  notes         String?

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  sourceId String?     @map("source_id")
  source   LeadSource? @relation(fields: [sourceId], references: [id])

  ownerId String? @map("owner_id")
  owner   User?   @relation("LeadOwner", fields: [ownerId], references: [id])

  priority Priority   @default(MEDIUM)
  status   LeadStatus @default(NEW)

  expectedDealValue   Decimal?  @map("expected_deal_value") @db.Decimal(14, 2)
  probability         Int?
  expectedClosingDate DateTime? @map("expected_closing_date")
  lostReason          String?   @map("lost_reason")

  lastContactAt    DateTime? @map("last_contact_at")
  nextFollowUp     DateTime? @map("next_follow_up")
  firstContactedAt DateTime? @map("first_contacted_at")

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("LeadCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities LeadActivity[]
  comments   LeadComment[]
  views      LeadView[]

  @@index([ownerId])
  @@index([status])
  @@index([serviceId])
  @@index([phone])
  @@index([email])
  @@index([state])
  @@index([city])
  @@map("leads")
}

model LeadActivity {
  id        String         @id @default(cuid())
  leadId    String         @map("lead_id")
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?        @map("user_id")
  user      User?          @relation(fields: [userId], references: [id])
  action    ActivityAction
  notes     String?
  timestamp DateTime       @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

model LeadComment {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@map("lead_comments")
}

// One row per (lead, user, day) — "did this rep open this lead today", deduped so normal
// page re-renders/refetches don't inflate the count. Powers "profiles opened" metrics.
model LeadView {
  id       String   @id @default(cuid())
  leadId   String   @map("lead_id")
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewDate DateTime @map("view_date") @db.Date
  viewedAt DateTime @default(now()) @map("viewed_at")

  @@unique([leadId, userId, viewDate])
  @@index([userId])
  @@map("lead_views")
}

model AssignmentRule {
  id        String  @id @default(cuid())
  serviceId String  @unique @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])
  teamId    String  @map("team_id")
  team      Team    @relation(fields: [teamId], references: [id])

  @@map("assignment_rules")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}
